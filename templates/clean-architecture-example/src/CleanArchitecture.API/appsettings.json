{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DatabaseConnectionString": "Server=localhost;Database=db_clean_architecture;Trusted_Connection=True;Encrypt=False;"
  },
  "JwtSettings": {
    "Key": "THIS_IS_A_SAMPLE_DEVELOPMENT_KEY_CHANGE_IT",
    "Issuer": "CleanArchitecture.Api",
    "Audience": "CleanArchitectureUser",
    "DurationInMinutes": 15
  },
  "UseInMemoryDatabase": true,
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterva": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
